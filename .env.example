# 复制为 .env 后填入真实值
# ⚠️ 真实 .env 文件请勿提交到 git！

# ============ 核心必填 ============
# 智谱 GLM API Key（必填，否则 /api/chat 接口不可用）
# 获取地址：https://open.bigmodel.cn/
GLM_API_KEY=your_glm_api_key_here

# PostgreSQL 容器初始化账号（docker-compose 首次启动时创建）
POSTGRES_USER=admin
POSTGRES_PASSWORD=123456
POSTGRES_DB=smart_home

# 后端连数据库的 URL（指向 compose 服务名 db）
DATABASE_URL=postgresql://admin:123456@db:5432/smart_home

# ============ 可选 ============
# JWT 签名密钥（启用用户系统后必填，建议 32+ 字符随机串）
JWT_SECRET=change-me-to-a-random-32-char-string
JWT_EXPIRES_HOURS=24

# CORS 允许的前端域名（逗号分隔，留空则允许所有来源）
# 生产示例：CORS_ORIGINS=https://home.example.com,https://www.home.example.com
CORS_ORIGINS=

# 真实天气 API（不填则用模拟随机温度）
# 申请地址：https://openweathermap.org/api
WEATHER_API_KEY=
WEATHER_CITY=北京

# 数据库连接池
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600

# 日志级别
LOG_LEVEL=INFO

# 前端构建时注入的 API 地址；nginx 已经反代 /api → backend，
# 所以生产构建用同源相对路径即可
VITE_API_BASE=
